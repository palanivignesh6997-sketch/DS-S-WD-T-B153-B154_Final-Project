import streamlit as st
import sqlite3
import os

from langchain_chroma import Chroma
from langchain_huggingface import HuggingFaceEmbeddings

embedding_model = HuggingFaceEmbeddings(
    model_name="sentence-transformers/all-MiniLM-L6-v2"
)

vectordb = Chroma(
    persist_directory="acko_db",
    embedding_function=embedding_model
)

retriever = vectordb.as_retriever(
    search_kwargs={"k":3}
)

llm = ChatGoogleGenerativeAI(
    model="models/gemini-2.5-flash",
    temperature=0
)

conn = sqlite3.connect(
    "chat_history.db",
    check_same_thread=False
)

cursor = conn.cursor()

cursor.execute("""
CREATE TABLE IF NOT EXISTS conversations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    question TEXT,
    answer TEXT,
    sources TEXT
)
""")

conn.commit()


def save_conversation(question, answer, sources):

    conn = sqlite3.connect("chat_history.db")

    cursor = conn.cursor()

    cursor.execute("""
    INSERT INTO conversations
    (question, answer, sources)
    VALUES (?, ?, ?)
    """,
    (
        question,
        answer,
        ", ".join(sources)
    ))

    conn.commit()
    conn.close()

def ask_question(question):

    docs = retriever.invoke(question)

    context = "\n\n".join(
        [doc.page_content for doc in docs]
    )

    sources = list(
        set(
            [doc.metadata["source"] for doc in docs]
        )
    )

    prompt = f"""
You are an ACKO Insurance Assistant.

Answer only using provided context.

If information is unavailable,
say:
'I could not find this information in the policy documents.'

Context:
{context}

Question:
{question}
"""

    response = llm.invoke(prompt)

    answer = response.content

    save_conversation(
        question,
        answer,
        sources
    )

    return {
        "answer": answer,
        "sources": sources
    }


st.set_page_config(
    page_title="ACKO Insurance Assistant",
    layout="wide"
)

st.title("ACKO Insurance Assistant")

tab1, tab2, tab3 = st.tabs(
    [
        "FAQ Questions",
        "Ask Question",
        "History"
    ]
)

with tab1:

    faq_questions = [

        "What is IDV in car insurance?",
        "What does comprehensive car insurance cover?",
        "Is car insurance mandatory in India?",
        "What is No Claim Bonus?",
        "How do I file a motor insurance claim?",
        "Do I need insurance for my bike?",
        "How much does bike insurance cost?",
        "Can I transfer my NCB?",
        "What is a waiting period in health insurance?",
        "What add-ons are recommended for a new car?"
    ]

    selected_question = st.selectbox(
        "Select a Question",
        faq_questions
    )

    if st.button("Get Answer"):

        result = ask_question(
            selected_question
        )

        st.subheader("Answer")

        st.write(
            result["answer"]
        )

        st.subheader("Sources")

        for src in result["sources"]:

            st.write(
                os.path.basename(src)
            )

with tab2:

    question = st.text_area(
        "Enter your question"
    )

    if st.button("Ask Question"):

        if question.strip():

            result = ask_question(
                question
            )

            st.subheader("Answer")

            st.write(
                result["answer"]
            )

            st.subheader("Sources")

            for src in result["sources"]:

                st.write(
                    os.path.basename(src)
                )

with tab3:

    conn = sqlite3.connect(
        "chat_history.db"
    )

    cursor = conn.cursor()

    rows = cursor.execute("""
    SELECT question,
           answer,
           sources
    FROM conversations
    ORDER BY id DESC
    LIMIT 20
    """).fetchall()

    conn.close()

    for q, a, s in rows:

        with st.expander(q):

            st.write(a)

            st.write(s)

